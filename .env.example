# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe — required for payment links and subscriptions (phase 4)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Price IDs created in Stripe dashboard
STRIPE_PRICE_AGENCY_SUBSCRIPTION=price_...

# Resend (transactional email)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=no-reply@platform.innovena.no

# Anthropic (Claude) — powers the AI quote-request wizard.
# Without this key the wizard falls back to a manual flow.
ANTHROPIC_API_KEY=sk-ant-...
